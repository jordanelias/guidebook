__pycache__/

# DB dry-run copies (used by handoff doc commands)
data/.test-copy.db

# working-copy pilot DBs (throwaway; canonical DB is data/guidebook.db)
working/pilot/*.db

# transient SQLite sidecars from read-only WAL-mode connections (never work product;
# the canonical DB is committed as a single binary)
data/guidebook.db-shm
data/guidebook.db-wal

# derived structural-audit graph (throwaway build artifact; rebuilt each run by
# scripts/audit/graph_audit.py; never migration-tracked, never canonical)
data/audit_graph.db
data/audit_graph.db-shm
data/audit_graph.db-wal
